---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Percetakan Makassar - Sigap & Cepat!',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Tanya Harga via WA',
        href: 'https://wa.me/6281381622530',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
      { text: 'Lihat Contoh Percetakan', href: 'https://wa.me/6281381622530' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1607192233397-3b2d1e2d83f2?auto=format&fit=crop&w=2070&q=80',
      alt: 'Undangan Mewah',
    }}
  >
    <Fragment slot="title">
      Percetakan Undangan <span class="text-accent dark:text-white">Expres</span> di Makassar
    </Fragment>

    <Fragment slot="subtitle">
      Solusi Terlengkap: <span class="font-semibold text-blue-600"
        >Percetakan Undangan, hingga Undangan Website Modern.</span
      >
      <span class="block mt-2 font-bold text-red-600"
        >Khusus Pekan Ini: Gratis Pengetikan Label Nama untuk Setiap Pemesanan Undangan! 🚀</span
      >
    </Fragment>
  </Hero>

  <Note
    title="Keunggulan Kami:"
    description="Hasil Cetak Tajam, Pengerjaan Buku Yasin Kilat, dan Desain Undangan Website yang Interaktif."
  />

  <Features
    id="features"
    tagline="Layanan Kami"
    title="Apa yang Anda Butuhkan?"
    subtitle="Kami fokus memberikan kualitas terbaik untuk momen spesial Anda dan keluarga di Makassar."
    items={[
      {
        title: 'Percetakan Kalender',
        description:
          'Tersedia berbagai pilihan. Pengerjaan rapi dan cepat.',
        icon: 'tabler:book',
      },
      {
        title: 'Percetakan Undangan',
        description:
          'Ratusan model undangan cetak mulai dari gaya minimalis hingga mewah dengan finishing poli emas/embos.',
        icon: 'tabler:mail-opened',
      },
      {
        title: 'Bikin Undangan Website',
        description:
          'Undangan digital kekinian dengan fitur RSVP, Map Lokasi, Galeri Foto, dan Musik latar. Link bisa disebar ke ribuan tamu.',
        icon: 'tabler:device-mobile-message',
      },
      {
        title: 'Percetakan Label Undangan',
        description:
          'Jasa pengetikan dan cetak label nama tamu (Stiker 103). Rapi, cepat, dan data tinggal kirim via Excel/WA.',
        icon: 'tabler:sticker',
      },
    ]}
  />

  <Content
    isReversed
    tagline="Spesialis Kalender"
    title="BKalender Spesial Mengenang Almarhum/ah"
    items={[
      {
        title: 'Banyak Pilihan Isi',
        description: 'Tersedia bermacam-macam dengan bahan kertas HVS atau Art Paper licin.',
      },
      {
        title: 'Cover Kustom & Eksklusif',
        description:
          'Desain cover bisa disesuaikan dengan keinginan keluarga, lengkap dengan pita pembatas dan sudut siku emas.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1544640808-32ca72ac7f37?auto=format&fit=crop&w=2070&q=80',
      alt: 'Buku Yasin Premium',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Penghormatan Terakhir yang Terbaik
      </h3>
      Buku Yasin yang rapi dan indah sebagai amal jariyah bagi almarhum/ah tercinta.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <Content
    isAfterContent
    tagline="Era Digital"
    title="Undangan Website: Sebar Tanpa Batas!"
    items={[
      {
        title: 'Link Khusus Nama Tamu',
        description: `Tampilan lebih personal dengan fitur "Kepada Bapak/Ibu..." pada link yang dikirimkan.`,
      },
      {
        title: 'Fitur Map & Navigasi',
        description: 'Tamu tidak akan tersesat karena sudah terhubung langsung dengan Google Maps atau Waze.',
      },
      {
        title: 'Fitur Angpao Digital',
        description: 'Memudahkan tamu memberikan kado atau ucapan melalui nomor rekening atau e-wallet yang terpasang.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1512486130939-2c4f79935e4f?auto=format&fit=crop&w=2070&q=80',
      alt: 'Digital Invitation Design',
    }}
  >
    <Fragment slot="content">Ganti cara lama dengan undangan website yang lebih praktis dan hemat biaya kirim.</Fragment
    >

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <Steps
    title="Proses Pesan Sangat Mudah"
    items={[
      {
        title: 'Step 1: Pilih Model & Kirim Data',
        description: 'Pilih model Yasin atau Undangan, lalu kirim data (nama, lokasi, foto) melalui WhatsApp.',
        icon: 'tabler:brand-whatsapp',
      },
      {
        title: 'Step 2: Proses Desain & Review',
        description: 'Tim kami akan mengerjakan desainnya. Anda bisa cek dan revisi sampai benar-benar pas.',
        icon: 'tabler:edit',
      },
      {
        title: 'Step 3: Produksi & Serah Terima',
        description: 'Pesanan langsung masuk mesin cetak. Untuk Undangan Website, link aktif dalam hitungan jam!',
        icon: 'tabler:printer',
      },
      {
        title: 'Pesanan Selesai!',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1586769852044-692d6e3703f0?auto=format&fit=crop&w=987&q=80',
      alt: 'Customer Service',
    }}
  />

  <FAQs
    title="Tanya Jawab (FAQ)"
    subtitle="Segala hal yang sering ditanyakan pelanggan Yasin & Undangan kami."
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'Berapa hari pengerjaan Buku Yasin?',
        description:
          'Untuk model softcover sekitar 2-4 hari, sedangkan hardcover eksklusif sekitar 5-7 hari tergantung jumlah pesanan.',
      },
      {
        title: 'Apakah undangan website bisa aktif selamanya?',
        description:
          'Masa aktif standar adalah 6 bulan - 1 tahun setelah hari H acara. Cukup lama untuk tamu melihat dokumentasi acara.',
      },
      {
        title: 'Data label undangan dikirim format apa?',
        description:
          'Cukup kirim daftar nama dalam format Excel atau list diketik biasa di WhatsApp, kami yang rapikan untuk cetaknya.',
      },
    ]}
  />

  <Stats
    stats={[
      { title: 'Buku Yasin Terbit', amount: '5K' },
      { title: 'Undangan Web Aktif', amount: '1.2K' },
      { title: 'Undangan Cetak', amount: '50K+' },
      { title: 'Label Nama Terketik', amount: '100K+' },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Hubungi Admin Sekarang',
        href: 'https://wa.me/62812345678',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  >
    <Fragment slot="title">
      Siap Membuat Momen <br class="block sm:hidden" /><span class="sm:whitespace-nowrap">Berharga Anda?</span>
    </Fragment>

    <Fragment slot="subtitle">
      Jangan tunda lagi. Konsultasikan kebutuhan Yasin atau Undangan Anda secara gratis sekarang juga!
    </Fragment>
  </CallToAction>
</Layout>
