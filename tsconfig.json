{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "strictNullChecks": true,
    "allowJs": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"]
    },
    "ignoreDeprecations": "5.0"
  },
  "include": [".astro/types.d.ts", "**/*", "src/env.d.ts"],
  "exclude": ["dist/", "node_modules/"]
}
